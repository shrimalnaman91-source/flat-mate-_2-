# Copy this file to .env.local and add your Google Maps API key
# Get one at: https://console.cloud.google.com/google/maps-apis/credentials
# Enable the "Maps JavaScript API" for your key
VITE_GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE

# Optional: a Map ID enables Advanced Markers and custom map styling
# Create one at: https://console.cloud.google.com/google/maps-apis/studio/maps
VITE_GOOGLE_MAPS_MAP_ID=
